# ─── GitHub Actions Secrets ───────────────────────────────────────────
# 아래 값들을 GitHub repo → Settings → Secrets and variables → Actions → New repository secret 에 등록

# Chrome Web Store API (Google Cloud Console에서 발급)
CHROME_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
CHROME_CLIENT_SECRET=your-google-oauth-client-secret
CHROME_REFRESH_TOKEN=your-chrome-webstore-refresh-token

# 버전 커밋용 Git 이메일
GIT_USER_EMAIL=your-email@example.com
